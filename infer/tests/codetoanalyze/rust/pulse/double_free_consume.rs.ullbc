from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" `*mut T` but non-zero and [covariant]."},{"DocComment":""},{"DocComment":" This is often the correct thing to use when building data structures using"},{"DocComment":" raw pointers, but is ultimately more dangerous to use because of its additional"},{"DocComment":" properties. If you're not sure if you should use `NonNull<T>`, just use `*mut T`!"},{"DocComment":""},{"DocComment":" Unlike `*mut T`, the pointer must always be non-null, even if the pointer"},{"DocComment":" is never dereferenced. This is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<NonNull<T>>` has the same size as `*mut T`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `NonNull<T>` is covariant over `T`. This is usually the correct"},{"DocComment":" choice for most data structures and safe abstractions, such as `Box`, `Rc`, `Arc`, `Vec`,"},{"DocComment":" and `LinkedList`."},{"DocComment":""},{"DocComment":" In rare cases, if your type exposes a way to mutate the value of `T` through a `NonNull<T>`,"},{"DocComment":" and you need to prevent unsoundness from variance (for example, if `T` could be a reference"},{"DocComment":" with a shorter lifetime), you should add a field to make your type invariant, such as"},{"DocComment":" `PhantomData<Cell<T>>` or `PhantomData<&'a mut T>`."},{"DocComment":""},{"DocComment":" Example of a type that must be invariant:"},{"DocComment":" ```rust"},{"DocComment":" use std::cell::Cell;"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":" struct Invariant<T> {"},{"DocComment":"     ptr: std::ptr::NonNull<T>,"},{"DocComment":"     _invariant: PhantomData<Cell<T>>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Notice that `NonNull<T>` has a `From` instance for `&T`. However, this does"},{"DocComment":" not change the fact that mutating through a (pointer derived from a) shared"},{"DocComment":" reference is undefined behavior unless the mutation happens inside an"},{"DocComment":" [`UnsafeCell<T>`]. The same goes for creating a mutable reference from a shared"},{"DocComment":" reference. When using this `From` instance without an `UnsafeCell<T>`,"},{"DocComment":" it is your responsibility to ensure that `as_mut` is never called, and `as_ptr`"},{"DocComment":" is never used for mutation."},{"DocComment":""},{"DocComment":" # Representation"},{"DocComment":""},{"DocComment":" Thanks to the [null pointer optimization],"},{"DocComment":" `NonNull<T>` and `Option<NonNull<T>>`"},{"DocComment":" are guaranteed to have the same size and alignment:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ptr::NonNull;"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<i16>>(), size_of::<Option<NonNull<i16>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<i16>>(), align_of::<Option<NonNull<i16>>>());"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<str>>(), size_of::<Option<NonNull<str>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<str>>(), align_of::<Option<NonNull<str>>>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [covariant]: https://doc.rust-lang.org/reference/subtyping.html"},{"DocComment":" [`PhantomData`]: crate::marker::PhantomData"},{"DocComment":" [`UnsafeCell<T>`]: crate::cell::UnsafeCell"},{"DocComment":" [null pointer optimization]: crate::option#representation"},{"Unknown":{"path":"rustc_nonnull_optimization_guaranteed","args":null}},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"NonNull\""}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"NonNull"},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":"Opaque","layout":null,"ptr_metadata":"None"},{"def_id":10,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["ptr",0]},{"Ident":["unique",0]},{"Ident":["Unique",0]},{"Monomorphized":{"regions":[],"types":[{"Literal":{"Int":"I32"}}],"const_generics":[],"trait_refs":[]}}],"span":{"span":{"file_id":11,"beg":{"line":37,"col":0},"end":{"line":37,"col":34}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" A wrapper around a raw non-null `*mut T` that indicates that the possessor"},{"DocComment":" of this wrapper owns the referent. Useful for building abstractions like"},{"DocComment":" `Box<T>`, `Vec<T>`, `String`, and `HashMap<K, V>`."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `Unique<T>` behaves \"as if\" it were an instance of `T`."},{"DocComment":" It implements `Send`/`Sync` if `T` is `Send`/`Sync`. It also implies"},{"DocComment":" the kind of strong aliasing guarantees an instance of `T` can expect:"},{"DocComment":" the referent of the pointer should not be modified without a unique path to"},{"DocComment":" its owning Unique."},{"DocComment":""},{"DocComment":" If you're uncertain of whether it's correct to use `Unique` for your purposes,"},{"DocComment":" consider using `NonNull`, which has weaker semantics."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, the pointer must always be non-null, even if the pointer"},{"DocComment":" is never dereferenced. This is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<Unique<T>>` has the same size as `Unique<T>`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `Unique<T>` is covariant over `T`. This should always be correct"},{"DocComment":" for any type which upholds Unique's aliasing requirements."},{"Unknown":{"path":"doc","args":"hidden"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"ptr_unique"},"generics":{"regions":[],"types":