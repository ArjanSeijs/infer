is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<Unique<T>>` has the same size as `Unique<T>`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `Unique<T>` is covariant over `T`. This should always be correct"},{"DocComment":" for any type which upholds Unique's aliasing requirements."}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":0,"beg":{"line":1,"col":0},"end":{"line":1,"col":0}},"generated_from_span":null},"origin":"WhereClauseOnType","trait_":{"regions":[],"skip_binder":{"id":3,"generics":{"regions":[],"types":[{"HashConsedValue":[7,{"TypeVar":{"Bound":[1,0]}}]}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":"Opaque","layout":null,"ptr_metadata":"None","repr":{"repr_algo":"Rust","align_modif":null,"transparent":true,"explicit_discr_type":false}},{"def_id":2,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["ptr",0]},{"Ident":["non_null",0]},{"Ident":["NonNull",0]}],"span":{"data":{"file_id":9,"beg":{"line":76,"col":0},"end":{"line":76,"col":35}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" `*mut T` but non-zero and [covariant]."},{"DocComment":""},{"DocComment":" This is often the correct thing to use when building data structures using"},{"DocComment":" raw pointers, but is ultimately more dangerous to use because of its additional"},{"DocComment":" properties. If you're not sure if you should use `NonNull<T>`, just use `*mut T`!"},{"DocComment":""},{"DocComment":" Unlike `*mut T`, the pointer must always be non-null, even if the pointer"},{"DocComment":" is never dereferenced. This is so that enums may use this forbidden value"},{"DocComment":" as a discriminant -- `Option<NonNull<T>>` has the same size as `*mut T`."},{"DocComment":" However the pointer may still dangle if it isn't dereferenced."},{"DocComment":""},{"DocComment":" Unlike `*mut T`, `NonNull<T>` is covariant over `T`. This is usually the correct"},{"DocComment":" choice for most data structures and safe abstractions, such as `Box`, `Rc`, `Arc`, `Vec`,"},{"DocComment":" and `LinkedList`."},{"DocComment":""},{"DocComment":" In rare cases, if your type exposes a way to mutate the value of `T` through a `NonNull<T>`,"},{"DocComment":" and you need to prevent unsoundness from variance (for example, if `T` could be a reference"},{"DocComment":" with a shorter lifetime), you should add a field to make your type invariant, such as"},{"DocComment":" `PhantomData<Cell<T>>` or `PhantomData<&'a mut T>`."},{"DocComment":""},{"DocComment":" Example of a type that must be invariant:"},{"DocComment":" ```rust"},{"DocComment":" use std::cell::Cell;"},{"DocComment":" use std::marker::PhantomData;"},{"DocComment":" struct Invariant<T> {"},{"DocComment":"     ptr: std::ptr::NonNull<T>,"},{"DocComment":"     _invariant: PhantomData<Cell<T>>,"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Notice that `NonNull<T>` has a `From` instance for `&T`. However, this does"},{"DocComment":" not change the fact that mutating through a (pointer derived from a) shared"},{"DocComment":" reference is undefined behavior unless the mutation happens inside an"},{"DocComment":" [`UnsafeCell<T>`]. The same goes for creating a mutable reference from a shared"},{"DocComment":" reference. When using this `From` instance without an `UnsafeCell<T>`,"},{"DocComment":" it is your responsibility to ensure that `as_mut` is never called, and `as_ptr`"},{"DocComment":" is never used for mutation."},{"DocComment":""},{"DocComment":" # Representation"},{"DocComment":""},{"DocComment":" Thanks to the [null pointer optimization],"},{"DocComment":" `NonNull<T>` and `Option<NonNull<T>>`"},{"DocComment":" are guaranteed to have the same size and alignment:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ptr::NonNull;"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<i16>>(), size_of::<Option<NonNull<i16>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<i16>>(), align_of::<Option<NonNull<i16>>>());"},{"DocComment":""},{"DocComment":" assert_eq!(size_of::<NonNull<str>>(), size_of::<Option<NonNull<str>>>());"},{"DocComment":" assert_eq!(align_of::<NonNull<str>>(), align_of::<Option<NonNull<str>>>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [covariant]: https://doc.rust-lang.org/reference/subtyping.html"},{"DocComment":" [`PhantomData`]: crate::marker::PhantomData"},{"DocComment":" [`UnsafeCell<T>`]: crate::cell::UnsafeCell"},{"DocComment":" [null pointer optimization]: crate::option#representation"},{"Unknown":{"path":"rustc_nonnull_optimization_guaranteed","args":null}},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"NonNull\""}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"NonNull"},"generics":{"regions":[],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":0,"beg":{"line":1,"col":0},"end":{"line":1,"col":0}},"generated_from_span":null},"origin":"WhereClauseOnType","trait_":{"regions":[],"skip_binder":{"id":3,"generics":{"regions":[],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"src":"TopLevel","kind":"Opaque","layout":null,"ptr_metadata":"None","repr":{"repr_algo":"Rust","align_modif":null,"transparent":true,"explicit_discr_type":false}},null,null,{"def_id":5,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["alloc",0]},{"Ident":["layout",0]},{"Ident":["Layout",0]}],"span":{"data":{"file_id":10,"beg":{"line":30,"col":0},"end":{"line":30,