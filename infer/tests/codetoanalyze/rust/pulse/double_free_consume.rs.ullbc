rker",0]},{"Ident":["Sized",0]}],"span":{"data":{"file_id":4,"beg":{"line":161,"col":0},"end":{"line":161,"col":26}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Types with a constant size known at compile time."},{"DocComment":""},{"DocComment":" All type parameters have an implicit bound of `Sized`. The special syntax"},{"DocComment":" `?Sized` can be used to remove this bound if it's not appropriate."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # #![allow(dead_code)]"},{"DocComment":" struct Foo<T>(T);"},{"DocComment":" struct Bar<T: ?Sized>(T);"},{"DocComment":""},{"DocComment":" // struct FooUse(Foo<[i32]>); // error: Sized is not implemented for [i32]"},{"DocComment":" struct BarUse(Bar<[i32]>); // OK"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" The one exception is the implicit `Self` type of a trait. A trait does not"},{"DocComment":" have an implicit `Sized` bound as this is incompatible with [trait object]s"},{"DocComment":" where, by definition, the trait needs to work with all possible implementors,"},{"DocComment":" and thus could be any size."},{"DocComment":""},{"DocComment":" Although Rust will let you bind `Sized` to a trait, you won't"},{"DocComment":" be able to use it to form a trait object later:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # #![allow(unused_variables)]"},{"DocComment":" trait Foo { }"},{"DocComment":" trait Bar: Sized { }"},{"DocComment":""},{"DocComment":" struct Impl;"},{"DocComment":" impl Foo for Impl { }"},{"DocComment":" impl Bar for Impl { }"},{"DocComment":""},{"DocComment":" let x: &dyn Foo = &Impl;    // OK"},{"DocComment":" // let y: &dyn Bar = &Impl; // error: the trait `Bar` cannot be made into an object"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [trait object]: ../../book/ch17-02-trait-objects.html"},{"Unknown":{"path":"diagnostic::on_unimplemented","args":"message =\n\"the size for values of type `{Self}` cannot be known at compilation time\",\nlabel = \"doesn't have a size known at compile-time\""}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"sized"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[{"clause_id":0,"span":{"data":{"file_id":4,"beg":{"line":161,"col":17},"end":{"line":161,"col":26}},"generated_from_span":null},"origin":"WhereClauseOnTrait","trait_":{"regions":[],"skip_binder":{"id":0,"generics":{"regions":[],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[]}}}}],"consts":[],"types":[],"methods":[],"vtable":null},{"def_id":2,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["alloc",0]},{"Ident":["Allocator",0]}],"span":{"data":{"file_id":6,"beg":{"line":106,"col":0},"end":{"line":106,"col":32}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" An implementation of `Allocator` can allocate, grow, shrink, and deallocate arbitrary blocks of"},{"DocComment":" data described via [`Layout`][]."},{"DocComment":""},{"DocComment":" `Allocator` is designed to be implemented on ZSTs, references, or smart pointers."},{"DocComment":" An allocator for `MyAlloc([u8; N])` cannot be moved, without updating the pointers to the"},{"DocComment":" allocated memory."},{"DocComment":""},{"DocComment":" In contrast to [`GlobalAlloc`][], `Allocator` allows zero-sized allocations. If an underlying"},{"DocComment":" allocator does not support this (like jemalloc) or responds by returning a null pointer"},{"DocComment":" (such as `libc::malloc`), this must be caught by the implementation."},{"DocComment":""},{"DocComment":" ### Currently allocated memory"},{"DocComment":""},{"DocComment":" Some of the methods require that a memory block is *currently allocated* by an allocator."},{"DocComment":" This means that:"},{"DocComment":"  * the starting address for that memory block was previously"},{"DocComment":"    returned by [`allocate`], [`grow`], or [`shrink`], and"},{"DocComment":"  * the memory block has not subsequently been deallocated."},{"DocComment":""},{"DocComment":" A memory block is deallocated by a call to [`deallocate`],"},{"DocComment":" or by a call to [`grow`] or [`shrink`] that returns `Ok`."},{"DocComment":" A call to `grow` or `shrink` that returns `Err`,"},{"DocComment":" does not deallocate the memory block passed to it."},{"DocComment":""},{"DocComment":" [`allocate`]: Allocator::allocate"},{"DocComment":" [`grow`]: Allocator::grow"},{"DocComment":" [`shrink`]: Allocator::shrink"},{"DocComment":" [`deallocate`]: Allocator::deallocate"},{"DocComment":""},{"DocComment":" ### Memory fitting"},{"DocComment":""},{"DocComment":" Some of the methods require that a `layout` *fit* a memory block or vice versa. This means that the"},{"DocComment":" following conditions must hold:"},{"DocComment":"  * the memory block must be *currently allocated* with alignment of [`layout.align()`], and"},{"DocComment":"  * [`layout.size()`] must fall in the range `min ..= max`, where:"},{"DocComment":"    - `min` is the size of the layout used to allocate the block, and"},{"DocComment":"    - `max` is the actual size returned from [`allocate`], [`grow`], or [`shrink`]."},{"DocComment":""},{"DocComment":" [`layout.align()`]: Layout::align"},{"DocComment":" [`layout.size()`]: Layout::size"},{"DocComment":""},{"DocComment":" # Safety"},{"DocComment":""},{"DocComment":" Memory blocks that are [*currently allocated*] by an allocator,"},{"DocComment":" must point to valid memory, and retain their validity until either:"},{"DocComment":"  - the memory block is deallocated, or"},{"DocComment":"  - the allocator is dropped."},{"DocComment":""},{"DocComment":" Copying, cloning, or moving the allocator must not invalidate memory blocks returned from it."},{"DocComment":" A copied or cloned allocator must behave like the original allocator."},{"DocComment":""},{"DocComment":" A memory block which is [*currently allocated*] may be passed to"},{"DocComment":" any method of the allocator that accepts such an argument."},{"DocComment":""},{"DocComment":" [*currently allocated*]: #currently-allocated-memory"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[],"types":[{"index":0,"name":"Self"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[{"clause_id":0,"span":{"data":{"file_id":6,"beg":{"line":106,"col":0},"end":{"line":369,"col":1}},"generated_from_span":null},"origin":"WhereClauseOnTrait","trait_":{"regions":[],"skip_binder":{"id":0,"generics":{"regions":[],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":1,"span":{"data":{"file_id":0,"beg":{"line":1,"col":0},"end":{"line":1,"col":0}},"generated_from_span":null},"origin":"WhereClauseOnTrait","trait_":{"regions":[],"skip_binder":{"id":3,"generics":{"regions":[],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[]}}}}],"consts":[],"types":[],"methods":[{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"allocate","attr_info":{"attributes":[{"DocComment":" Attempts to allocate a block of memory."},{"DocComment":""},{"DocComment":" On success, returns a [`NonNull<[u8]>`][NonNull] meeting the size and alignment guarantees of `layout`."},{"DocComment":""},{"DocComment":" The returned block may have a larger size than specified by `layout.size()`, and may or may"},{"DocComment":" not have its contents initialized."},{"DocComment":""},{"DocComment":" The returned block of memory remains valid as long as it is [*currently allocated*] and the shorter of:"},{"DocComment":"   - the borrow-checker lifetime of the allocator type itself."},{"DocComment":"   - as long as the allocator and all its clones have not been dropped."},{"DocComment":""},{"DocComment":" [*currently allocated*]: #currently-allocated-memory"},{"DocComment":""},{"DocComment":" # Errors"},{"DocComment":""},{"DocComment":" Returning `Err` indicates that either memory is exhausted or `layout` does not meet"},{"DocComment":" allocator's size or alignment constraints."},{"DocComment":""},{"DocComment":" Implementations are encouraged to return `Err` on memory exhaustion rather than panicking or"},{"DocComment":" aborting, but this is not a strict requirement. (Specifically: it is *legal* to implement"},{"DocComment":" this trait atop an underlying native allocation library that aborts on memory exhaustion.)"},{"DocComment":""},{"DocComment":" Clients wishing to abort computation in response to an allocation error are encouraged to"},{"DocComment":" call the [`handle_alloc_error`] function, rather than directly invoking `panic!` or similar."},{"DocComment":""},{"DocComment":" [`handle_alloc_error`]: ../../alloc/alloc/fn.handle_alloc_error.html"}],"inline":null,"rename":null,"public":true},"item":{"id":3,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[{"HashConsedValue":[15,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":2,"generics":{"regions":[],"types":[{"HashConsedValue":[13,{"TypeVar":{"Bound":[2,0]}}]}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[2,"allocate"]}},{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"deallocate","attr_info":{"attributes":[{"DocComment":" Deallocates the memory referenced by `ptr`."},{"DocComment":""},{"DocComment":" # Safety"},{"DocComment":""},{"DocComment":" * `ptr` must denote a block of memory [*currently allocated*] via this allocator, and"},{"DocComment":" * `layout` must [*fit*] that block of memory."},{"DocComment":""},{"DocComment":" [*currently allocated*]: #currently-allocated-memory"},{"DocComment":" [*fit*]: #memory-fitting"}],"inline":null,"rename":null,"public":true},"item":{"id":5,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[{"Deduplicated":15}]}}},"kind":{"TraitMethod":[2,"deallocate"]}}],"vtable":{"id":{"Adt":4},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}},{"def_id":3,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["marker",0]},{"Ident":["Destruct",0]}],"span":{"data":{"file_id":4,"beg":{"line":1056,"col":0},"end":{"line":1056,"col":38}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" A marker for types that can be dropped."},{"DocComment":""},{"DocComment":" This should be used for `[const]` bounds,"},{"DocComment":" as non-const bounds will always hold for every type."},{"Unknown":{"path":"rustc_on_unimplemented","args":"message = \"can't drop `{Self}`\", append_const_msg"}}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"destruct"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[],"methods":[{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"drop_in_place","attr_info":{"attributes":[],"inline":null,"rename":null,"public":true},"item":{"id":17,"generics":{"regions":[],"types":[{"Deduplicated":7}],"const_generics":[],"trait_refs":[]}}},"kind":{"TraitMethod":[3,"drop_in_place"]}}],"vtable":null}],"trait_impls":[{"def_id":0,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["alloc",0]